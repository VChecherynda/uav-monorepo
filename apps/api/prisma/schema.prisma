// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Drone {
  id          String      @id @default(cuid())
  name        String
  status      String // "active" | "idle" | "offline"
  battery     Int
  altitude    Int
  lng         Float
  lat         Float
  homeLng     Float       @default(133.8800)
  homeLat     Float       @default(-23.7000)
  updatedAt   DateTime    @updatedAt
  createdAt   DateTime    @default(now())
  telemetries Telemetry[]
  missions    Mission[]
}

model Telemetry {
  id         String   @id @default(cuid())
  droneId    String
  battery    Int
  altitude   Int
  lng        Float
  lat        Float
  recordedAt DateTime @default(now())
  drone      Drone    @relation(fields: [droneId], references: [id])

  @@index([droneId, recordedAt])
}

model Mission {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(120)
  droneId   String?
  status    String     @default("draft") // "draft" | "assigned" | "in-progress | "completed" | "aborted"
  reason    String?
  createdAt DateTime   @default(now())
  drone     Drone?     @relation(fields: [droneId], references: [id], onDelete: Restrict)
  waypoints Waypoint[]
}

model Waypoint {
  id         String   @id @default(cuid())
  lng        Float
  lat        Float
  missionId  String
  order      Int
  recordedAt DateTime @default(now())
  mission    Mission  @relation(fields: [missionId], references: [id])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
